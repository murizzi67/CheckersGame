<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dama" Height="850" Width="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#202020">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--header-->
        <Border
                Background="#2D2D2D"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15">

            <DockPanel>

                <TextBlock x:Name="TxtTurno"
                           Text="Turno: Bianco"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Content="Nuova Partita"
                        Width="140"
                        Height="40"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#404040"
                        Foreground="White"
                        BorderBrush="#707070"
                        Click="BtnNuovaPartita_Click"/>

            </DockPanel>
        </Border>

        <!--scacchiera-->
        <Border Grid.Row="1"
                Background="#111111"
                Padding="10"
                CornerRadius="10">

            <UniformGrid x:Name="GrigliaScacchiera"
                         Rows="8"
                         Columns="8"/>

        </Border>

    </Grid>
</Window>